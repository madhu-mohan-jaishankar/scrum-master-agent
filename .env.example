# ─────────────────────────────────────────────────────────────────────────────
# WatsonX ScrumMaster Agent — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── IBM WatsonX AI ──────────────────────────────────────────────────────────
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID_CLASSIFY=ibm/granite-3-3-8b-instruct
WATSONX_MODEL_ID_GENERATE=ibm/granite-3-3-8b-instruct

# ── Redis (event bus + Sprint Context Store) ─────────────────────────────────
# Redis Stack required: provides both Streams and RediSearch/vector.
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_EVENTS=scrum:events:raw
REDIS_CONSUMER_GROUP=scrum-worker
REDIS_CONSUMER_NAME=worker-1

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITHUB_APP_TOKEN=your_github_app_token_or_pat

# ── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_DEFAULT_CHANNEL=#scrum-bot

# ── Ingestion Service ────────────────────────────────────────────────────────
INGESTION_HOST=127.0.0.1
INGESTION_PORT=8000

# ── Scheduler ────────────────────────────────────────────────────────────────
STANDUP_CRON=0 9 * * 1-5       # 09:00 Mon-Fri
PRE_STANDUP_CRON=45 8 * * 1-5  # 08:45 Mon-Fri

# ── Mock Mode ────────────────────────────────────────────────────────────────
# Set to 1 to run without Redis, WatsonX API keys, or Slack.
# All output is printed to the console.  Perfect for demos and local dev.
# Usage: SCRUMAGENT_MOCK=1 uv run python scripts/run_mock.py
#   or:  make mock
SCRUMAGENT_MOCK=0
